# ===== ClickUp =====
# Personal API Token (Settings > Apps > API Token). Começa com "pk_".
CLICKUP_API_TOKEN=

# (Opcional) Team/Workspace ID padrão. Descobrível via script de bootstrap.
CLICKUP_TEAM_ID=

# ===== Supabase =====
# Project URL (ex: https://xxxx.supabase.co)
SUPABASE_URL=
# Service role key (apenas backend — NUNCA expor no front)
SUPABASE_SERVICE_ROLE_KEY=
